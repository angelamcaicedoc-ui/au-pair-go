# Au Pair Go — Variables de Entorno
# Copia este archivo como .env.local y completa los valores

# API Key de Google Gemini
# Obtén tu clave en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Modelo de Gemini a usar (opcional, por defecto: gemini-1.5-flash)
# Opciones: gemini-1.5-flash, gemini-1.5-pro, gemini-2.0-flash-exp
GEMINI_MODEL=gemini-1.5-flash
